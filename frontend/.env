# ============================================================
# .env — Trading Bot UI Environment Configuration
# NEVER commit this file to version control
# ============================================================

# ── Application ───────────────────────────────────────────
APP_SECRET_KEY=dev-secret-key-change-in-production-2024
APP_ENV=development
APP_PORT=5000
FRONTEND_URL=http://localhost:5000

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=jwt-dev-secret-trading-bot-2024
JWT_EXPIRY_HOURS=24

# ── Africa's Talking (SMS — Sandbox) ──────────────────────
# Sandbox: https://account.africastalking.com/auth/register
# Use "sandbox" as username for sandbox environment
AT_USERNAME=sandbox
AT_API_KEY=atsk_uat_your_sandbox_api_key_here
AT_SENDER_ID=                          # Leave blank for sandbox (uses default)
AT_ENVIRONMENT=sandbox                 # sandbox | production

# ── Google Gmail API (Email — Sandbox / OAuth2) ───────────
# Create credentials at: https://console.cloud.google.com/
# OAuth2 Playground: https://developers.google.com/oauthplayground
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REFRESH_TOKEN=1//your-refresh-token-from-oauth-playground
GMAIL_SENDER=your-gmail@gmail.com

# ── OTP Configuration ─────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3

# ── Database (SQLite for dev, PostgreSQL for prod) ────────
DATABASE_URL=sqlite:///trading_bot.db

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_OTP=5/hour                  # Max OTP requests per hour per IP
RATE_LIMIT_LOGIN=10/hour
